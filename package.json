{
  "name": "http-lab",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.16.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "react-loader-spinner": "^8.0.2",
    "react-scripts": "5.0.1",
    "web-vitals": "^2.1.4"
  },
    "scripts": {
    "start": "react-scripts start",
    "server": "json-server --watch db.json --port 3001 --delay 500",
    "server:routes": "json-server --watch db.json --port 3001 --routes routes.json",
    "dev": "concurrently \"npm run server\" \"npm start\""
  },
  "devDependencies": {
    "concurrently": "^8.0.0"
  }
,
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
